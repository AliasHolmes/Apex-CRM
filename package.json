{
    "name": "react-example",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "tsx scripts/dev.ts",
        "dev:server": "tsx server.ts",
        "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
        "start": "node dist/server.cjs",
        "clean": "rm -rf dist server.js",
        "lint": "tsc --noEmit",
        "test:enrichment": "tsx --test test/enrichmentCache.test.ts test/linkedinEvidence.test.ts",
        "test:lead-search": "tsx --test test/leadSearchHelpers.test.ts",
        "test:brightdata-upgrade": "tsx --test test/brightDataUpgrade.test.ts",
        "test:llm": "tsx --test test/llmFallback.test.ts",
        "test:telemetry": "tsx --test test/telemetry.test.ts",
        "test:lead-engine": "tsx --test test/leadSearchHelpers.test.ts test/enrichmentCache.test.ts test/linkedinEvidence.test.ts test/brightDataUpgrade.test.ts test/llmFallback.test.ts test/telemetry.test.ts"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.29.0",
        "@radix-ui/react-dialog": "^1.1.16",
        "@radix-ui/react-label": "^2.1.9",
        "@radix-ui/react-slot": "^1.2.5",
        "@radix-ui/react-tabs": "^1.1.14",
        "@tailwindcss/vite": "^4.1.14",
        "@types/papaparse": "^5.5.2",
        "@vitejs/plugin-react": "^5.0.4",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "dotenv": "^17.2.3",
        "express": "^4.21.2",
        "lucide-react": "^0.546.0",
        "motion": "^12.23.24",
        "papaparse": "^5.5.3",
        "react": "^19.0.1",
        "react-dom": "^19.0.1",
        "tailwind-merge": "^3.6.0",
        "tailwindcss-animate": "^1.0.7",
        "vite": "^6.2.3"
    },
    "devDependencies": {
        "@types/express": "^4.17.21",
        "@types/node": "^22.14.0",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "autoprefixer": "^10.4.21",
        "esbuild": "^0.25.0",
        "tailwindcss": "^4.1.14",
        "tsx": "^4.21.0",
        "typescript": "~5.8.2",
        "vite": "^6.2.3"
    }
}
