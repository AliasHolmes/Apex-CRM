# OPENAI_API_KEY: Required for AI API calls.
# You can use a standard OpenAI key or a third-party compatible endpoint key.
OPENAI_API_KEY="sk-..."

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Google OAuth Credentials
# Required for Google login and Cloud Code API
GOOGLE_CLIENT_ID="your_google_client_id_here"
GOOGLE_CLIENT_SECRET="your_google_client_secret_here"

# TAVILY_API_KEY: Required for Tavily Search-backed LinkedIn prospect discovery.
# Get a free key from https://app.tavily.com (free monthly credits, no credit card required).
# Optional rotation: set TAVILY_API_KEYS to a JSON array or comma-separated list. Falls back to TAVILY_API_KEY.
TAVILY_API_KEYS=""
TAVILY_API_KEY="MY_TAVILY_API_KEY"
# Optional Tavily tuning. Keep basic to conserve free credits.
TAVILY_SEARCH_DEPTH="basic"
TAVILY_MAX_RESULTS="10"
TAVILY_INCLUDE_RAW_CONTENT="true"
TAVILY_COUNTRY="united states"
# Free plan safeguards. Defaults match Tavily's documented 1,000 monthly credits;
# a single scout run is capped at six credits and one advanced signal search.
TAVILY_MONTHLY_CREDIT_BUDGET="1000"
TAVILY_SCOUT_MAX_CREDITS_PER_SEARCH="6"
TAVILY_SCOUT_MAX_ADVANCED_SEARCHES="1"
TAVILY_SCOUT_EXTRACT_MAX_URLS="5"
# APEX_DB_PATH: Optional local SQLite database location for CRM lead storage.
# Defaults to .apex-data/apex-crm.sqlite when unset.
APEX_DB_PATH=".apex-data/apex-crm.sqlite"

# Bright Data MCP enrichment. Rapid/free mode exposes search_engine and
# scrape_as_markdown. The app never invokes Pro-only scrape_batch on this plan.
# Optional rotation: set BRIGHTDATA_API_TOKENS to a JSON array or comma-separated list. Falls back to BRIGHTDATA_API_TOKEN or API_TOKEN.
BRIGHTDATA_API_TOKENS=""
BRIGHTDATA_API_TOKEN="MY_BRIGHTDATA_API_TOKEN"
# Set to "pro" only after explicitly upgrading. Free/Rapid mode never calls
# structured-data, browser, or scrape_batch MCP tools.
BRIGHTDATA_PLAN="free"
BRIGHTDATA_MONTHLY_REQUEST_BUDGET="5000"
BRIGHTDATA_SCOUT_MAX_REQUESTS_PER_SEARCH="2"
BRIGHTDATA_FREE_BATCH_FALLBACK_MAX_URLS="2"
BRIGHTDATA_SEARCH_GEO_LOCATION="us"
BRIGHTDATA_ENRICHMENT_CAP=""
BRIGHTDATA_CACHE_TTL_DAYS="7"
BRIGHTDATA_BASE_TIMEOUT="180"
# Local MCP server subprocess overrides
BASE_TIMEOUT="180"
BASE_MAX_RETRIES="2"
LEAD_SEARCH_MAX_ROUNDS="4"
LEAD_SEARCH_MIN_SCORE="6"
LEAD_SEARCH_TIMEOUT_MS="0"
LEAD_SEARCH_RERANK_POOL_MULTIPLIER="3"
LEAD_SEARCH_RERANK_POOL_MAX="30"
BRIGHTDATA_MCP_TRANSPORT="local"
BRIGHTDATA_FAILURE_COOLDOWN_MS="5000"
# Bright Data search fallback. Values: off, fallback, secondary.
BRIGHTDATA_SEARCH_MODE="fallback"

# Post-filter profile enrichment controls.
BRIGHTDATA_PROFILE_ENRICHMENT_STAGE="post_filter"
BRIGHTDATA_PROFILE_CONCURRENCY="1"
BRIGHTDATA_PROFILE_MAX_PER_SEARCH=""
BRIGHTDATA_PROFILE_RETRY_MAX="2"

# Negative cache for failed Bright Data profile scrapes.
BRIGHTDATA_NEGATIVE_CACHE_TTL_HOURS="24"

# Optional company intent enrichment. Disabled by default.
BRIGHTDATA_COMPANY_INTENT_ENABLED="false"
BRIGHTDATA_COMPANY_INTENT_MIN_SCORE="8"
BRIGHTDATA_COMPANY_INTENT_MAX_PER_SEARCH="3"
# Free-first email discovery for accepted prospects.
# Uses Bright Data single-page Markdown scrapes first (capped by the free
# fallback limit), Tavily extract/search as fallback, then local fetch/DNS/pattern inference.
# Values: off, accepted_only, missing_only.
EMAIL_DISCOVERY_MODE="accepted_only"
EMAIL_DISCOVERY_MAX_PER_SEARCH="10"
EMAIL_DISCOVERY_CRAWL_TIMEOUT_MS="8000"
EMAIL_DISCOVERY_CACHE_TTL_DAYS="14"


# LLM Gateway & Fallback Configuration
# LiteLLM is the default app path. If the proxy route fails, the app also tries configured direct non-primary fallbacks.
# Set direct only when you intentionally want to bypass LiteLLM and start with the app-side provider chain.
LLM_GATEWAY_MODE="litellm"
LITELLM_BASE_URL="http://127.0.0.1:4000/v1"
LITELLM_MODEL="apex-primary"
LITELLM_MASTER_KEY="sk-local-litellm"

# Primary Byesu/OpenAI-compatible provider
OPENAI_API_KEY="sk-..."
BYESU_API_KEY="sk-..."
OPENAI_BASE="https://byesu.com/v1"
OPENAI_MODEL="gpt-5.5"
OPENAI_PROVIDER_NAME="Byesu"

# OpenRouter fallback
OPENROUTER_API_KEY="sk-or-..."
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
OPENROUTER_MODEL="poolside/laguna-m.1:free"
OPENROUTER_APP_TITLE="Apex CRM"
OPENROUTER_HTTP_REFERER=""

# Groq fallback
GROQ_API_KEY="gsk-..."
GROQ_BASE_URL="https://api.groq.com/openai/v1"
GROQ_MODEL="qwen/qwen3.6-27b"
# JSON output mode:
# on = always send response_format: { type: "json_object" }.
# off = never send response_format.
# auto = send response_format first; use off for normal text-mode JSON prompting through LiteLLM routing.
LLM_JSON_MODE="off"

# Provider error handling & timeouts
LLM_TIMEOUT_MS="45000"
LLM_MAX_RETRIES="0"
# Lead extraction LLM controls. Smaller chunks and lower concurrency reduce malformed/truncated JSON from slower or verbose models.
LEAD_EXTRACTION_MAX_TOKENS="3000"
LEAD_EXTRACTION_CHUNK_CHARS="3200"
LEAD_EXTRACTION_CONCURRENCY="1"

# Mining observability. Search logs are cached in SQLite and capped after each session write.
SEARCH_LOG_RETENTION_LIMIT="50"
# Optional estimated LLM cost rates for observability-only math. Set to your provider pricing per 1M tokens.
LLM_OBSERVABILITY_INPUT_COST_PER_1M="0"
LLM_OBSERVABILITY_OUTPUT_COST_PER_1M="0"

# LLM Gateway rate limiting and cooldown adjustments
LLM_RATE_LIMIT_COOLDOWN_MS="30000"
LLM_PROVIDER_FAILURE_COOLDOWN_MS="10000"
LLM_MAX_COOLDOWN_WAIT_MS="30000"
LLM_EXTRACTION_CHUNK_CHARS="4500"
LLM_EXTRACTION_CONCURRENCY="2"
