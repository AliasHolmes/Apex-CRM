{
    "name": "react-example",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "tsx scripts/dev.ts",
        "dev:server": "tsx server.ts",
        "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
        "start": "node dist/server.cjs --production",
        "clean": "rm -rf dist server.js",
        "lint": "tsc --noEmit",
        "test:enrichment": "tsx --test test/enrichmentCache.test.ts test/linkedinEvidence.test.ts",
        "test:lead-search": "tsx --test test/leadSearchHelpers.test.ts",
        "test:brightdata-upgrade": "tsx --test test/brightDataUpgrade.test.ts",
        "test:key-rotation": "tsx --test test/keyRotator.test.ts test/tavilyRotation.test.ts",
        "test:llm": "tsx --test test/llmFallback.test.ts",
        "test:telemetry": "tsx --test test/telemetry.test.ts",
        "test:glyphs": "tsx --test test/encodingHygiene.test.ts",
        "test:lead-engine": "tsx --test test/leadSearchHelpers.test.ts test/enrichmentCache.test.ts test/linkedinEvidence.test.ts test/brightDataUpgrade.test.ts test/keyRotator.test.ts test/tavilyRotation.test.ts test/llmFallback.test.ts test/telemetry.test.ts test/encodingHygiene.test.ts"
    },
    "dependencies": {
        "@brightdata/mcp": "^2.11.0",
        "@modelcontextprotocol/sdk": "^1.29.0",
        "@radix-ui/react-dialog": "^1.1.19",
        "@radix-ui/react-label": "^2.1.11",
        "@radix-ui/react-slot": "^1.3.0",
        "@radix-ui/react-tabs": "^1.1.17",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "dotenv": "^17.2.3",
        "express": "^5.2.1",
        "lucide-react": "^1.24.0",
        "motion": "^12.42.2",
        "papaparse": "^5.5.4",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "tailwind-merge": "^3.6.0",
        "tailwindcss-animate": "^1.0.7"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.3.2",
        "@types/express": "^5.0.6",
        "@types/node": "^24.0.0",
        "@types/papaparse": "^5.5.2",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.3",
        "autoprefixer": "^10.5.2",
        "esbuild": "^0.28.1",
        "tailwindcss": "^4.3.2",
        "tsx": "^4.23.0",
        "typescript": "^7.0.2",
        "vite": "^8.1.4"
    }
}
