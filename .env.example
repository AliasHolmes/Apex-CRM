# OPENAI_API_KEY: Required for AI API calls.
# You can use a standard OpenAI key or a third-party compatible endpoint key.
OPENAI_API_KEY="sk-..."

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Google OAuth Credentials
# Required for Google login and Cloud Code API
GOOGLE_CLIENT_ID="your_google_client_id_here"
GOOGLE_CLIENT_SECRET="your_google_client_secret_here"

# TAVILY_API_KEY: Required for Tavily Search-backed LinkedIn prospect discovery.
# Get a free key from https://app.tavily.com (free monthly credits, no credit card required).
TAVILY_API_KEY="MY_TAVILY_API_KEY"
# Optional Tavily tuning. Keep basic to conserve free credits.
TAVILY_SEARCH_DEPTH="basic"
TAVILY_MAX_RESULTS="10"
TAVILY_INCLUDE_RAW_CONTENT="true"
TAVILY_COUNTRY="united states"
# APEX_DB_PATH: Optional local SQLite database location for CRM lead storage.
# Defaults to .apex-data/apex-crm.sqlite when unset.
APEX_DB_PATH=".apex-data/apex-crm.sqlite"

# Bright Data MCP enrichment. Free tier uses scrape_as_markdown only.
BRIGHTDATA_API_TOKEN="MY_BRIGHTDATA_API_TOKEN"
BRIGHTDATA_ENRICHMENT_CAP=""
BRIGHTDATA_CACHE_TTL_DAYS="7"
BRIGHTDATA_BASE_TIMEOUT="15"
LEAD_SEARCH_MAX_ROUNDS="4"
LEAD_SEARCH_MIN_SCORE="6"
LEAD_SEARCH_TIMEOUT_MS="0"
BRIGHTDATA_MCP_TRANSPORT="hosted"
BRIGHTDATA_FAILURE_COOLDOWN_MS="600000"
# Bright Data search fallback. Values: off, fallback, secondary.
BRIGHTDATA_SEARCH_MODE="fallback"

# Post-filter profile enrichment controls.
BRIGHTDATA_PROFILE_ENRICHMENT_STAGE="post_filter"
BRIGHTDATA_PROFILE_CONCURRENCY="2"
BRIGHTDATA_PROFILE_MAX_PER_SEARCH=""

# Negative cache for failed Bright Data profile scrapes.
BRIGHTDATA_NEGATIVE_CACHE_TTL_HOURS="24"

# Optional company intent enrichment. Disabled by default.
BRIGHTDATA_COMPANY_INTENT_ENABLED="false"
BRIGHTDATA_COMPANY_INTENT_MIN_SCORE="8"
BRIGHTDATA_COMPANY_INTENT_MAX_PER_SEARCH="3"

# LLM Gateway & Fallback Configuration
# LLM gateway mode:
# direct = current behavior, calls Byesu directly.
# litellm = calls local LiteLLM proxy, which uses Byesu first and OpenRouter fallback.
LLM_GATEWAY_MODE="direct"

# Direct Byesu mode
OPENAI_API_KEY="sk-..."
OPENAI_BASE="https://api.byesu.com/v1"
OPENAI_MODEL="gpt-5.5"

# LiteLLM proxy mode
LITELLM_MASTER_KEY="sk-local-litellm"
BYESU_API_KEY="sk-..."
OPENROUTER_API_KEY="sk-or-..."
GROQ_API_KEY="gsk-..."
LITELLM_BASE_URL="http://localhost:4000/v1"
LITELLM_MODEL="apex-primary"

# JSON output mode:
# on = always send response_format: { type: "json_object" }.
# off = never send response_format.
# auto = send it first; if LiteLLM/OpenRouter returns 400/422, retry once without response_format.
LLM_JSON_MODE="auto"

# Provider error handling & timeouts
LLM_TIMEOUT_MS="120000"
LLM_MAX_RETRIES="1"
LLM_RETRY_429="true"

